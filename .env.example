# Asana Personal Access Token
# Generieren Sie einen Token unter: https://app.asana.com/-/user_account_settings/developer_console
ASANA_TOKEN=your_personal_access_token_here

# Optional: Obsidian Vault Pfad (kann auch via --vault CLI Argument übergeben werden)
# OBSIDIAN_VAULT_PATH=~/Obsidian/MyVault
